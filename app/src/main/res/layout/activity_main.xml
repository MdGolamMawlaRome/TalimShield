<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F4F6F9">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="মায়ের তালিম সুরক্ষা"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1B5E20"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="32dp"/>

    <!-- ক্যামেরা সেকশন -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:padding="20dp"
        android:layout_marginBottom="16dp"
        android:elevation="2dp">
        
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="১. ক্যামেরা (ভিডিও) বন্ধ রাখুন"
            android:textSize="18sp"
            android:textColor="#333333"
            android:textStyle="bold"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/camSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- মাইক সেকশন -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:padding="20dp"
                            android:layout_marginBottom="32dp"
        android:elevation="2dp">
        
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="২. মাইক (আওয়াজ) বন্ধ রাখুন"
            android:textSize="18sp"
            android:textColor="#333333"
            android:textStyle="bold"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/micSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- সহজ নির্দেশনা -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="সহজ নিয়ম:\n\nতালিম শোনার আগে উপরের দুটি সুইচ ডানদিকে টেনে চালু করে দিন। এতে আপনার ছবি এবং গলার আওয়াজ গ্রুপে আর কেউ দেখতে বা শুনতে পাবে না। আপনি একদম নিরাপদে তালিম শুনতে পারবেন।"
        android:textSize="16sp"
        android:textColor="#555555"
        android:lineSpacingMultiplier="1.3"
        android:background="#E8F5E9"
        android:padding="16dp"/>
</LinearLayout>
